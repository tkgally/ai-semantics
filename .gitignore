# manifest (ids/gold/stratum), never the corpus example sentences.
experiments/data/wic/
experiments/runs/2026-05-31-lexical-polysemy-homonymy-v3/fulltext.jsonl

# Hawkins/Stanford tangrams repeated-reference corpus (GitHub license: null;
# authors' "open corpus" release statement only; re-downloadable, sha256 pinned in
# the resource page). Recipe-not-corpus posture: commit only the download recipe +
# the derived aggregate entrainment table, NEVER the raw utterances.
experiments/data/hawkins-tangrams/
